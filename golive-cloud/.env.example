# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to Git

# MongoDB
MONGODB_URI=mongodb://localhost:27017/golive_cloud

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=https://cloud.golivecompany.com

# Portal admin credentials (hashed at first login)
ADMIN_EMAIL=admin@golivenaija.com
ADMIN_PASSWORD=change_this_password

# Email — Microsoft 365 SMTP
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=info@golivenaija.com
SMTP_PASS=your_email_password
NOTIFY_EMAIL=info@golivenaija.com

# Public settings
NEXT_PUBLIC_SITE_URL=https://cloud.golivecompany.com
NEXT_PUBLIC_WA_NUMBER=2348083587801
